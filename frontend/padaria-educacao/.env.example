# Modo da aplicação: "development" ou "production"
# Em desenvolvimento: usa https://ead-api.dcmmarketingdigital.com.br como API base (padrão Sail)
# Em produção: usa https://ead-api.dcmmarketingdigital.com.br como API base
# Nota: o frontend lê do .env raiz do projeto (via envDir no vite.config.ts)
VITE_APP_MODE=development

# URL base da API — se omitido, é derivado automaticamente do VITE_APP_MODE
# Dev:  https://ead-api.dcmmarketingdigital.com.br
# Prod: https://ead-api.dcmmarketingdigital.com.br
VITE_API_BASE=https://ead-api.dcmmarketingdigital.com.br

# Pusher (notificações em tempo real)
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=us2

# Web Push (receber notificações mesmo fora da plataforma)
VITE_VAPID_PUBLIC_KEY=
